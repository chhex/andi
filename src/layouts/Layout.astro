---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
	title?: string;
	description?: string;
}
const {
	title = "André Behr – Journalist & Ghostwriter",
	description = "Über 40 Jahre Erfahrung als Sportjournalist. André Behr schreibt Biographien, Porträts und Texte für Menschen, die ihre Geschichte professionell erzählt haben möchten.",
} = Astro.props;

const canonicalUrl = Astro.url.href;
const ogImage = Astro.site
	? new URL("/images/andre.jpg", Astro.site).href
	: null;
---

<!doctype html>
<html lang="de" data-theme="andre">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
</html>
