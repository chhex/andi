---
import Layout from "../layouts/Layout.astro";
import IconDownload from "../components/IconDownload.astro";
import IconExternalLink from "../components/IconExternalLink.astro";


const referenzen = [
  {
    titel: "Schach-News: Carlsen und Caruana überzeugen",
    medium: "Tages-Anzeiger",
    typ: "link",
    url: "https://www.tagesanzeiger.ch/schach-news-carlsen-und-caruana-ueberzeugen-in-weissenhaus-663206189448",
    beschreibung: "Hintergrundbericht über das Schachturnier in Weissenhaus.",
  },
  {
    titel: "Beispiel Reportage",
    medium: "Verlag XYZ",
    typ: "pdf",
    url: "/dokumente/artikel.pdf",
    beschreibung: "Ein Buch als Beispiel der schriftstellerischen Arbeit.",
  },
];
---

<Layout title="Referenzen – André Behr">
  <section class="page-section">
    <p class="page-label">Referenzen</p>
    <h1 class="page-title">Medien & Erfahrung</h1>
    <div class="max-w-2xl space-y-8">
      {referenzen.map((ref) => (
        <div class="page-divider">
          <p class="item-label">{ref.medium}</p>
          <h2 class="item-title">{ref.titel}</h2>
          <p class="item-text">{ref.beschreibung}</p>
          <a
            href={ref.url}
            target="_blank"
            rel="noopener noreferrer"
            class="ref-btn"
          >
            {ref.typ === "pdf" ? (
              <>
                <IconDownload />
                PDF öffnen
              </>
            ) : (
              <>
                <IconExternalLink />
                Artikel lesen
              </>
            )}
          </a>
        </div>
      ))}
      <div class="page-divider-footer">
        <p class="page-text italic text-sm">
          Weitere Arbeitsproben auf Anfrage erhältlich.
        </p>
      </div>
    </div>
  </section>
</Layout>
