---
import Layout from "../layouts/Layout.astro";
import referenzen from "../../content/referenzen.json";
import IconDownload from "../components/IconDownload.astro";
import IconExternalLink from "../components/IconExternalLink.astro";
import IconVideo from "../components/IconVideo.astro";
import IconAudio from "../components/IconAudio.astro";
import IconBild from "../components/IconBild.astro";

const getIcon = (typ: string) => {
  switch (typ) {
    case "pdf":
      return IconDownload;
    case "video":
      return IconVideo;
    case "audio":
      return IconAudio;
    case "bild":
      return IconBild;
    default:
      return IconExternalLink;
  }
};

const getLabel = (typ: string) => {
  switch (typ) {
    case "pdf":
      return "PDF öffnen";
    case "video":
      return "Video ansehen";
    case "audio":
      return "Audio anhören";
    case "bild":
      return "Bild ansehen";
    default:
      return "Artikel lesen";
  }
};

// Jahrzehnte dynamisch berechnen
const jahrzehnte = [
  ...new Set(
    referenzen.referenzen
      .filter((r) => r.datum)
      .map((r) => Math.floor(new Date(r.datum).getFullYear() / 10) * 10),
  ),
].sort();

// Alle Tags dynamisch sammeln
const alleTags = [
  ...new Set(referenzen.referenzen.flatMap((r) => r.tags || [])),
].sort();
---

<Layout title="Referenzen – André Behr">
  <section class="page-section">
    <p class="page-label">Referenzen</p>
    <h1 class="page-title">Medien & Erfahrung</h1>

    <!-- Filter -->
    <div class="mb-8 space-y-4">
      <div class="flex flex-wrap gap-2 items-center">
        <span class="contact-label w-16">Typ:</span>
        <button class="filter-btn filter-typ ref-btn active" data-typ="alle"
          >Alle</button
        >
        <button class="filter-btn filter-typ ref-btn" data-typ="link"
          >Artikel</button
        >
        <button class="filter-btn filter-typ ref-btn" data-typ="pdf">PDF</button
        >
        <button class="filter-btn filter-typ ref-btn" data-typ="video"
          >Video</button
        >
        <button class="filter-btn filter-typ ref-btn" data-typ="audio"
          >Audio</button
        >
        <button class="filter-btn filter-typ ref-btn" data-typ="bild"
          >Bild</button
        >
      </div>
      <div class="flex flex-wrap gap-2 items-center">
        <span class="contact-label w-16">Periode:</span>
        <button
          class="filter-btn filter-jahr ref-btn active"
          data-jahrzehnt="alle">Alle</button
        >
        {
          jahrzehnte.map((j) => (
            <button class="filter-btn filter-jahr ref-btn" data-jahrzehnt={j}>
              {j}er
            </button>
          ))
        }
      </div>
      <div class="flex flex-wrap gap-2 items-center">
        <span class="contact-label w-16">Tags:</span>
        <div class="relative" id="tag-dropdown-container">
          <button
            id="tag-dropdown-btn"
            class="ref-btn gap-2 min-w-48 justify-between"
          >
            <span id="tag-dropdown-label">Tags auswählen</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div
            id="tag-dropdown"
            class="hidden absolute z-10 mt-1 w-64 bg-base-100 border border-base-300 shadow-lg max-h-64 overflow-y-auto"
          >
            {
              alleTags.map((tag) => (
                <label class="flex items-center gap-3 px-4 py-2 hover:bg-base-200 cursor-pointer text-sm">
                  <input
                    type="checkbox"
                    class="checkbox checkbox-sm"
                    value={tag}
                  />
                  <span>{tag}</span>
                </label>
              ))
            }
          </div>
        </div>
        <button id="tag-reset" class="ref-btn"> Reset </button>
        <div id="tag-badges" class="flex flex-wrap gap-1"></div>
      </div>
    </div>

    <!-- Anzahl sichtbare Referenzen -->
    <p class="item-label mb-4" id="anzahl"></p>

    <!-- Referenzen Liste -->
    <div class="max-w-2xl space-y-8" id="referenzen-liste">
      {
        referenzen.referenzen.map((ref) => {
          const Icon = getIcon(ref.typ);
          const label = getLabel(ref.typ);
          const jahr = ref.datum ? new Date(ref.datum).getFullYear() : null;
          const jahrzehnt = jahr ? Math.floor(jahr / 10) * 10 : null;
          const datumFormatiert = ref.datum
            ? new Date(ref.datum).toLocaleDateString("de-CH", {
                year: "numeric",
                month: "long",
              })
            : null;

          return (
            <div
              class="page-divider ref-item"
              data-typ={ref.typ}
              data-jahrzehnt={jahrzehnt}
              data-tags={JSON.stringify(ref.tags || [])}
            >
              <div class="flex items-start justify-between gap-4 mb-1">
                <p class="item-label">{ref.medium}</p>
                {datumFormatiert && <p class="item-label">{datumFormatiert}</p>}
              </div>
              <h2 class="item-title">{ref.titel}</h2>
              <p class="item-text">{ref.beschreibung}</p>

              {ref.tags && ref.tags.length > 0 && (
                <div class="flex flex-wrap gap-1 mb-3">
                  {ref.tags.map((tag) => (
                    <span class="text-xs border border-base-300 px-2 py-0.5 text-base-content/50">
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              {ref.typ === "video" &&
                ref.embed &&
                (ref.embed.includes("youtube") ||
                ref.embed.includes("vimeo") ? (
                  <div class="mt-4 aspect-video w-full">
                    <iframe
                      src={ref.embed}
                      title={ref.titel}
                      class="w-full h-full"
                      allowfullscreen
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="mt-4">
                    <video controls class="w-full">
                      <source src={ref.embed} type="video/mp4" />
                      Ihr Browser unterstützt kein Video.
                    </video>
                  </div>
                ))}

              {ref.typ === "audio" && ref.embed && (
                <div class="mt-4">
                  <audio controls class="w-full">
                    <source src={ref.embed} type="audio/mpeg" />
                    Ihr Browser unterstützt kein Audio.
                  </audio>
                </div>
              )}

              {ref.typ === "bild" && ref.embed && (
                <div class="mt-4">
                  <img
                    src={ref.embed}
                    alt={ref.titel}
                    class="w-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}

              {ref.url &&
                (!ref.embed || ref.typ === "link" || ref.typ === "pdf") && (
                  <a
                    href={ref.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="ref-btn mt-4"
                  >
                    <Icon />
                    {label}
                  </a>
                )}
            </div>
          );
        })
      }
      <div class="page-divider-footer">
        <p class="page-text italic text-sm">
          Weitere Arbeitsproben auf Anfrage erhältlich.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  let aktivTyp = 'alle';
  let aktivJahrzehnt = 'alle';
  let aktivTags: string[] = [];

  const filterItems = () => {
    const items = document.querySelectorAll('.ref-item');
    let anzahl = 0;

    items.forEach(item => {
      const el = item as HTMLElement;
      const typ = el.dataset.typ || '';
      const jahrzehnt = el.dataset.jahrzehnt || '';
      const tags: string[] = JSON.parse(el.dataset.tags || '[]');

      const typMatch = aktivTyp === 'alle' || typ === aktivTyp;
      const jahrMatch = aktivJahrzehnt === 'alle' || jahrzehnt === aktivJahrzehnt;
      const tagMatch = aktivTags.length === 0 || aktivTags.some(t => tags.includes(t));

      const sichtbar = typMatch && jahrMatch && tagMatch;
      el.style.display = sichtbar ? 'block' : 'none';
      if (sichtbar) anzahl++;
    });

    const anzahlEl = document.getElementById('anzahl');
    if (anzahlEl) anzahlEl.textContent = `${anzahl} Referenz${anzahl !== 1 ? 'en' : ''} gefunden`;
  };

  const updateBadges = () => {
    const badgesEl = document.getElementById('tag-badges');
    const labelEl = document.getElementById('tag-dropdown-label');
    if (!badgesEl || !labelEl) return;

    badgesEl.innerHTML = aktivTags.map(tag => `
      <span class="inline-flex items-center gap-1 text-xs border border-base-300 px-2 py-0.5 bg-base-200">
        ${tag}
        <button class="tag-badge-remove hover:text-error" data-tag="${tag}">×</button>
      </span>
    `).join('');

    labelEl.textContent = aktivTags.length === 0 
      ? 'Tags auswählen' 
      : `${aktivTags.length} Tag${aktivTags.length !== 1 ? 's' : ''} gewählt`;

    // Badge Remove Buttons
    document.querySelectorAll('.tag-badge-remove').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const tag = (btn as HTMLElement).dataset.tag || '';
        aktivTags = aktivTags.filter(t => t !== tag);
        const checkbox = document.querySelector(`input[type="checkbox"][value="${tag}"]`) as HTMLInputElement;
        if (checkbox) checkbox.checked = false;
        updateBadges();
        filterItems();
      });
    });
  };

  const setFilter = (gruppe: string, wert: string) => {
    document.querySelectorAll(`.filter-${gruppe}`).forEach(b => {
      b.classList.remove('active', 'bg-base-300');
    });
    document.querySelector(`.filter-${gruppe}[data-${gruppe === 'typ' ? 'typ' : 'jahrzehnt'}="${wert}"]`)
      ?.classList.add('active', 'bg-base-300');
  };

  // Typ Filter
  document.querySelectorAll('.filter-typ').forEach(btn => {
    btn.addEventListener('click', () => {
      aktivTyp = (btn as HTMLElement).dataset.typ || 'alle';
      setFilter('typ', aktivTyp);
      filterItems();
    });
  });

  // Jahr Filter
  document.querySelectorAll('.filter-jahr').forEach(btn => {
    btn.addEventListener('click', () => {
      aktivJahrzehnt = (btn as HTMLElement).dataset.jahrzehnt || 'alle';
      setFilter('jahr', aktivJahrzehnt);
      filterItems();
    });
  });

  // Dropdown Toggle
  const dropdownBtn = document.getElementById('tag-dropdown-btn');
  const dropdown = document.getElementById('tag-dropdown');

  dropdownBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdown?.classList.toggle('hidden');
  });

  // Dropdown schliessen bei Klick ausserhalb
  document.addEventListener('click', () => {
    dropdown?.classList.add('hidden');
  });

  dropdown?.addEventListener('click', (e) => {
    e.stopPropagation();
  });

  // Checkboxen
  document.querySelectorAll('#tag-dropdown input[type="checkbox"]').forEach(cb => {
    cb.addEventListener('change', () => {
      const checkbox = cb as HTMLInputElement;
      const tag = checkbox.value;
      if (checkbox.checked) {
        aktivTags = [...aktivTags, tag];
      } else {
        aktivTags = aktivTags.filter(t => t !== tag);
      }
      updateBadges();
      filterItems();
    });
  });

  // Reset
  document.getElementById('tag-reset')?.addEventListener('click', () => {
    aktivTags = [];
    document.querySelectorAll('#tag-dropdown input[type="checkbox"]').forEach(cb => {
      (cb as HTMLInputElement).checked = false;
    });
    updateBadges();
    filterItems();
  });

  // Initial
  filterItems();
  updateBadges();
</script>
