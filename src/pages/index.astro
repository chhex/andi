---
import Layout from "../layouts/Layout.astro";
---

<Layout title="André Behr – Journalist & Ghostwriter">
  <section class="py-16">
    <p class="text-sm uppercase tracking-widest text-stone-400 mb-4">
      Journalist · Ghostwriter · Biograph
    </p>
    <h1 class="text-4xl font-semibold text-stone-800 leading-snug mb-6">
      Geschichten, die bleiben.
    </h1>
    <p class="text-lg text-stone-600 max-w-2xl leading-relaxed mb-10">
      Über 40 Jahre Erfahrung als Sportjournalist – für Tages-Anzeiger, NZZ und weitere 
      Medien. Heute schreibe ich Biographien, Porträts und Texte für Menschen, 
      die ihre Geschichte professionell erzählt haben möchten.
    </p>
    <a 
  href="/kontakt" 
  class="inline-block bg-stone-900 text-white px-6 py-3 text-sm tracking-wide hover:bg-stone-700 transition-colors"
>

      Kontakt aufnehmen
    </a>
  </section>
</Layout>
