---
import Layout from "../layouts/Layout.astro";
import kontakt from "../../content/kontakt.json";
---

<Layout title="Kontakt – André Behr">
  <section class="page-section">
    <p class="page-label">Kontakt</p>
    <h1 class="page-title">{kontakt.header}</h1>
    <div class="max-w-xl page-text space-y-6">
      <p>{kontakt.intro}</p>
      <div class="space-y-3 mt-8">
        <p>
          <span class="contact-label">Email</span><br/>
          <a href={`mailto:${kontakt.email}`} class="contact-link">
            {kontakt.email}
          </a>
        </p>
        <p>
          <span class="contact-label">LinkedIn</span><br/>
          <a
            href={kontakt.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="contact-link"
          >
            {kontakt.linkedintxt}
          </a>
        </p>
      </div>
    </div>
  </section>
</Layout>
