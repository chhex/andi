---
const path = Astro.url.pathname;
const navClass = (href: string) =>
  `hover:text-base-content transition-colors ${path === href ? 'text-base-content' : ''}`;
---

<header class="w-full border-b border-base-300 bg-base-100 py-6 px-8">
  <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
    <a href="/" class="text-xl font-semibold tracking-wide text-primary">
      André Behr
    </a>
    <div class="flex items-center gap-8">
      <nav class="flex flex-wrap justify-center gap-4 sm:gap-8 text-sm text-base-content/60">
        <a href="/" class={navClass('/')}>Home</a>
        <a href="/ueber-mich" class={navClass('/ueber-mich')}>Über mich</a>
        <a href="/angebot" class={navClass('/angebot')}>Angebot</a>
        <a href="/referenzen" class={navClass('/referenzen')}>Archiv</a>
        <a href="/kontakt" class={navClass('/kontakt')}>Kontakt</a>
        x<a href="/statistiken" class="hover:text-base-content transition-colors">Statistiken</a>
      </nav>
      <div class="flex items-center gap-4">
        <select id="theme-switcher" class="select select-sm text-xs">
          <option value="andre">André</option>
          <option value="light">Light</option>
          <option value="dark">Dark</option>
          <option value="cupcake">Cupcake</option>
          <option value="bumblebee">Bumblebee</option>
          <option value="emerald">Emerald</option>
          <option value="corporate">Corporate</option>
          <option value="synthwave">Synthwave</option>
          <option value="retro">Retro</option>
          <option value="cyberpunk">Cyberpunk</option>
          <option value="valentine">Valentine</option>
          <option value="halloween">Halloween</option>
          <option value="garden">Garden</option>
          <option value="forest">Forest</option>
          <option value="aqua">Aqua</option>
          <option value="lofi">Lofi</option>
          <option value="pastel">Pastel</option>
          <option value="fantasy">Fantasy</option>
          <option value="wireframe">Wireframe</option>
          <option value="black">Black</option>
          <option value="luxury">Luxury</option>
          <option value="dracula">Dracula</option> 
          <option value="cmyk">Cmyk</option>  
          <option value="autumn">Autumn</option>  
          <option value="business">Business</option>  
          <option value="acid">Acid</option>  
          <option value="lemonade">Lemonade</option>  
          <option value="night">Night</option>  
          <option value="coffee">Coffee</option>  
          <option value="winter">Winter</option>  
          <option value="dim">Dim</option>  
          <option value="nord">Nord</option>  
          <option value="sunset">Sunset</option>  
          <option value="caramellatte">Caramellatte</option>  
          <option value="abyss">Abyss</option>  
          <option value="silk">Silk</option>  
        </select>
        <a 
          href="https://www.linkedin.com/in/andré-behr-a7517a94/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-base-content/40 hover:text-primary transition-colors"
          aria-label="LinkedIn Profil"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const switcher = document.getElementById('theme-switcher') as HTMLSelectElement;
  switcher.value = document.documentElement.getAttribute('data-theme') || 'andre';
  switcher.addEventListener('change', (e) => {
    const theme = (e.target as HTMLSelectElement).value;
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  });
</script>
